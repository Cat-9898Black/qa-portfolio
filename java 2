// Интерфейс - контракт 
interface Shape {
    double area();  // Посчитать
площадь
   void draw();    // Нарисовать
   }
// Круг
class Circle implements Shape {
    private double radius;
    
    public  Circle (double radius)
    { this.radius = radius; }
    
    public double area() {return 
    Math.PI * radius * radius; }
    public  void draw()
    { System.out.println("О (площадь: "
    + area() + ")"); }
}
// Квадрат
class Square implements Shape {
   private double side; 
   
   public Square (double side)
   { this.side = side; }
   
    public double area() {return
    side * side; }
    public void draw()
    { System.out.println("[] (площадь: "
    + area() + ")"); }
}
 public class Main {
     public static void 
main(String[] args) {
        Shape circle = new
 Circle(5);  // Круг с радиусом 5
 Square(4);  // Квадрат с стороной 4
 
        сircle.draw();
        square.draw();
    }
 }
}
 }
